{
  "name": "obs-media-frame",
  "version": "0.1.0",
  "description": "画像や動画をポンと入れてOBSの固定枠に表示するアプリ。",
  "main": "src/main.js",
  "author": "配信ピタポン contributors",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/core.js && node --check src/preload.js && node --check src/renderer.js && node --check src/player.js",
    "test": "node test/core.test.js",
    "verify": "npm run check && npm test",
    "dist": "electron-builder --win nsis portable",
    "dist:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "jp.obspicture.haishinpitapon",
    "productName": "配信ピタポン",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json",
      "LICENSE"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "artifactName": "Stream-PitaPon-${version}-${arch}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "Stream-PitaPon-${version}-${arch}-Portable.${ext}"
    }
  }
}
